{
  "version": 6,
  "configurePresets": [
    {
      "name": "base-vcpkg",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "BUILD_TESTING": "ON",
        "CMAKE_PREFIX_PATH": "$env{QT_ROOT};$env{CMAKE_PREFIX_PATH}"
      }
    },
    {
      "name": "windows-vcpkg",
      "displayName": "Windows x64 (vcpkg)",
      "inherits": "base-vcpkg",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/windows-vcpkg"
    },
    {
      "name": "linux-vcpkg",
      "displayName": "Linux x64 (vcpkg)",
      "inherits": "base-vcpkg",
      "binaryDir": "${sourceDir}/out/build/linux-vcpkg"
    },
    {
      "name": "macos-vcpkg",
      "displayName": "macOS (vcpkg)",
      "inherits": "base-vcpkg",
      "binaryDir": "${sourceDir}/out/build/macos-vcpkg"
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vcpkg-debug",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "linux-vcpkg-debug",
      "configurePreset": "linux-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "linux-vcpkg-release",
      "configurePreset": "linux-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "macos-vcpkg-release",
      "configurePreset": "macos-vcpkg",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-vcpkg-debug",
      "configurePreset": "windows-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "linux-vcpkg-debug",
      "configurePreset": "linux-vcpkg"
    },
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "linux-vcpkg-release",
      "configurePreset": "linux-vcpkg",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "macos-vcpkg-release",
      "configurePreset": "macos-vcpkg",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}