<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="系统处理流程">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="2100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="XML 语法校验工具系统处理流程" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="30" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="start" value="开始" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="110" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="1. 用户在 GUI 中选择&#xa;XML 文件和 XSD 文件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="550" y="220" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="2. GUI 层检查&#xa;文件路径是否为空" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="350" width="280" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ex1" value="提示用户补充选择文件&#xa;不发起校验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="930" y="360" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="3. 输入检查模块检查文件状态&#xa;是否存在 / 是否为普通文件 / 是否可读" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="510" width="360" height="90" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="文件状态&#xa;是否有效？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="570" y="650" width="260" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ex2" value="显示阻断性异常提示&#xa;如文件不存在、无权限等" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="930" y="660" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ex_end" value="结束本次操作" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="810" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="4. 路径统一转换为绝对路径" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="550" y="810" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="5. GUI 调用业务逻辑层提供的&#xa;XmlValidator 接口发起校验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="930" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="6. XmlValidator 初始化并配置&#xa;Xerces-C++ 解析器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="1060" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="7. Xerces-C++ 加载并校验&#xa;指定 XSD 文件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="1190" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="8. Xerces-C++ 解析 XML 文件&#xa;并执行 Schema 校验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="1320" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s9h" value="9. 自定义 ErrorHandler 收集&#xa;解析和校验过程中的错误信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="1450" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s9" value="10. XmlValidator 将错误信息封装为&#xa;ValidationResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="1580" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="ValidationResult&#xa;校验状态" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="570" y="1710" width="260" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ok" value="11a. GUI 显示校验成功结果&#xa;绿色提示条：XML 通过校验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="210" y="1720" width="290" height="90" as="geometry" />
        </mxCell>
        <mxCell id="bad" value="11b. GUI 显示校验失败结果&#xa;红色提示条 + 错误数量 + 错误表格" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="1720" width="310" height="90" as="geometry" />
        </mxCell>
        <mxCell id="log" value="12. 日志模块记录本次校验过程和结果&#xa;校验时间 / 文件路径 / 状态 / 错误详情" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="1870" width="400" height="90" as="geometry" />
        </mxCell>
        <mxCell id="end" value="结束" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="2000" width="200" height="60" as="geometry" />
        </mxCell>

        

