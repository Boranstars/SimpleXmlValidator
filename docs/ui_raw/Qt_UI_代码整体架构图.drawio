<mxfile host="app.diagrams.net" modified="2026-07-21T12:00:00.000Z" agent="ChatGPT" version="26.0.0" type="device">
  <diagram id="qt-ui-architecture" name="Qt UI代码整体架构">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="&lt;b&gt;XML 语法校验工具——Qt UI 设计代码整体架构&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:13px&quot;&gt;忽略图标与视觉润色逻辑，突出界面组成、事件流、展示层与校验层关系&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="1000" height="60" as="geometry"/>
        </mxCell>

        <!-- 1. Qt事件入口 -->
        <mxCell id="eventLayer" value="&lt;b&gt;① Qt 事件与用户操作入口&lt;/b&gt;" style="swimlane;html=1;rounded=1;startSize=34;horizontal=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="300" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="menuToolbar" value="&lt;b&gt;菜单栏 / 工具栏&lt;/b&gt;&lt;br&gt;QMenuBar、QMenu、QToolBar、QAction&lt;br&gt;打开 XML、打开 XSD、开始校验、清空" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#60a5fa;fontColor=#1f2937;align=left;spacing=8;" vertex="1" parent="eventLayer">
          <mxGeometry x="20" y="50" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="directControls" value="&lt;b&gt;界面控件事件&lt;/b&gt;&lt;br&gt;QPushButton、QComboBox、QTableWidget&lt;br&gt;浏览、校验、重置、翻页、选择错误" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#60a5fa;fontColor=#1f2937;align=left;spacing=8;" vertex="1" parent="eventLayer">
          <mxGeometry x="20" y="140" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="dragDrop" value="&lt;b&gt;拖放事件&lt;/b&gt;&lt;br&gt;eventFilter() → DragEnter / Drop&lt;br&gt;提取本地 XML/XSD 文件路径" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#60a5fa;fontColor=#1f2937;align=left;spacing=8;" vertex="1" parent="eventLayer">
          <mxGeometry x="20" y="230" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- 2. MainWindow -->
        <mxCell id="mainWindow" value="&lt;b&gt;② MainWindow：界面总控制器 / 协调器&lt;/b&gt;" style="swimlane;html=1;rounded=1;startSize=38;horizontal=1;fillColor=#eef2ff;strokeColor=#4f46e5;fontColor=#312e81;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="700" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="setupUi" value="&lt;b&gt;setupUi()&lt;/b&gt;&lt;br&gt;创建窗口、菜单、工具栏、三栏布局、标签页、表格、状态栏，并完成信号槽连接" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#818cf8;align=left;spacing=8;" vertex="1" parent="mainWindow">
          <mxGeometry x="20" y="55" width="205" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="fileInput" value="&lt;b&gt;文件与输入管理&lt;/b&gt;&lt;br&gt;onSelectXml / onSelectXsd&lt;br&gt;setXmlPath / setXsdPath&lt;br&gt;refreshFileList / loadXmlPreview" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#818cf8;align=left;spacing=8;" vertex="1" parent="mainWindow">
          <mxGeometry x="245" y="55" width="205" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="validationCoord" value="&lt;b&gt;校验流程协调&lt;/b&gt;&lt;br&gt;updateValidateButtonState()&lt;br&gt;onValidate()&lt;br&gt;计时、调用 validator、更新状态栏" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#818cf8;align=left;spacing=8;" vertex="1" parent="mainWindow">
          <mxGeometry x="470" y="55" width="205" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="resultRender" value="&lt;b&gt;结果渲染&lt;/b&gt;&lt;br&gt;clearResultArea()&lt;br&gt;applyPresented()&lt;br&gt;提示条、状态卡片、日志、统计、阻断弹窗" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#818cf8;align=left;spacing=8;" vertex="1" parent="mainWindow">
          <mxGeometry x="85" y="180" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="pagingDetail" value="&lt;b&gt;分页与错误详情&lt;/b&gt;&lt;br&gt;renderErrorPage()&lt;br&gt;onPrevPage / onNextPage&lt;br&gt;onPageSizeChanged / updateErrorDetail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#818cf8;align=left;spacing=8;" vertex="1" parent="mainWindow">
          <mxGeometry x="365" y="180" width="240" height="100" as="geometry"/>
        </mxCell>

        <!-- 3. UI布局 -->
        <mxCell id="viewLayer" value="&lt;b&gt;③ Qt 界面组合结构&lt;/b&gt;" style="swimlane;html=1;rounded=1;startSize=38;horizontal=1;fillColor=#f0fdfa;strokeColor=#0f766e;fontColor=#134e4a;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="100" width="410" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="topChrome" value="&lt;b&gt;窗口顶层&lt;/b&gt;&lt;br&gt;QMenuBar + QToolBar + QStatusBar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2dd4bf;align=center;" vertex="1" parent="viewLayer">
          <mxGeometry x="25" y="55" width="360" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="splitter" value="&lt;b&gt;QSplitter（三栏主体）&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#14b8a6;fontStyle=1;align=center;" vertex="1" parent="viewLayer">
          <mxGeometry x="25" y="130" width="360" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="leftPanel" value="&lt;b&gt;左侧：文件列表&lt;/b&gt;&lt;br&gt;QListWidget&lt;br&gt;展示当前 XML / XSD 文件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2dd4bf;align=left;spacing=8;" vertex="1" parent="viewLayer">
          <mxGeometry x="25" y="195" width="110" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="centerPanel" value="&lt;b&gt;中间：主工作区&lt;/b&gt;&lt;br&gt;输入配置 QGroupBox&lt;br&gt;状态卡片&lt;br&gt;QTabWidget：校验结果 / XML预览 / 错误日志 / 统计信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2dd4bf;align=left;spacing=8;" vertex="1" parent="viewLayer">
          <mxGeometry x="145" y="195" width="240" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="rightPanel" value="&lt;b&gt;右侧：错误详情&lt;/b&gt;&lt;br&gt;级别 / 文件 / 行 / 列&lt;br&gt;描述文本 + 上下文代码" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2dd4bf;align=left;spacing=8;" vertex="1" parent="viewLayer">
          <mxGeometry x="25" y="335" width="110" height="125" as="geometry"/>
        </mxCell>
        <mxCell id="resultWidgets" value="&lt;b&gt;结果控件&lt;/b&gt;&lt;br&gt;QTableWidget：错误列表&lt;br&gt;QComboBox + QPushButton：分页&lt;br&gt;QPlainTextEdit：日志&lt;br&gt;QLabel：统计信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2dd4bf;align=left;spacing=8;" vertex="1" parent="viewLayer">
          <mxGeometry x="145" y="400" width="240" height="80" as="geometry"/>
        </mxCell>

        <!-- 4. 支撑组件 -->
        <mxCell id="supportLayer" value="&lt;b&gt;④ GUI 支撑组件&lt;/b&gt;" style="swimlane;html=1;rounded=1;startSize=38;horizontal=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="470" width="530" height="360" as="geometry"/>
        </mxCell>
        <mxCell id="codeEditor" value="&lt;b&gt;CodeEditor : QPlainTextEdit&lt;/b&gt;&lt;br&gt;只读、禁用自动换行&lt;br&gt;设置首行号、错误行高亮&lt;br&gt;维护 ExtraSelection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb923c;align=left;spacing=8;" vertex="1" parent="supportLayer">
          <mxGeometry x="20" y="55" width="230" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="lineNumberArea" value="&lt;b&gt;LineNumberArea : QWidget&lt;/b&gt;&lt;br&gt;计算宽度、绘制行号&lt;br&gt;跟随编辑器滚动和缩放" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb923c;align=left;spacing=8;" vertex="1" parent="supportLayer">
          <mxGeometry x="280" y="55" width="225" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="highlighter" value="&lt;b&gt;XmlSyntaxHighlighter : QSyntaxHighlighter&lt;/b&gt;&lt;br&gt;标签、括号、属性名、属性值、实体引用、多行注释高亮&lt;br&gt;绑定 CodeEditor 的 QTextDocument" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb923c;align=left;spacing=8;" vertex="1" parent="supportLayer">
          <mxGeometry x="20" y="190" width="230" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="styleModule" value="&lt;b&gt;Style + style.qss&lt;/b&gt;&lt;br&gt;applicationStyleSheet() 从资源路径读取 QSS&lt;br&gt;统一菜单、工具栏、输入框、按钮、卡片、标签页、表格等样式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb923c;align=left;spacing=8;" vertex="1" parent="supportLayer">
          <mxGeometry x="280" y="190" width="225" height="110" as="geometry"/>
        </mxCell>

        <!-- 5. 展示模型 -->
        <mxCell id="presenterLayer" value="&lt;b&gt;⑤ 结果展示适配层&lt;/b&gt;" style="swimlane;html=1;rounded=1;startSize=38;horizontal=1;fillColor=#fdf4ff;strokeColor=#a21caf;fontColor=#701a75;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="470" width="430" height="270" as="geometry"/>
        </mxCell>
        <mxCell id="presenter" value="&lt;b&gt;ValidationResultPresenter&lt;/b&gt;&lt;br&gt;initial()：生成初始展示模型&lt;br&gt;present()：将领域校验结果转换为界面展示结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d946ef;align=left;spacing=8;" vertex="1" parent="presenterLayer">
          <mxGeometry x="25" y="55" width="380" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="presentLogic" value="&lt;b&gt;主要转换规则&lt;/b&gt;&lt;br&gt;• Valid / Invalid / Failed → Banner 与状态卡片&lt;br&gt;• 统计 Error / Warning&lt;br&gt;• 合并完全相同诊断并记录 occurrences&lt;br&gt;• 控制表格、截断标记和阻断弹窗" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d946ef;align=left;spacing=8;" vertex="1" parent="presenterLayer">
          <mxGeometry x="25" y="155" width="380" height="75" as="geometry"/>
        </mxCell>

        <!-- 6. 校验与基础设施 -->
        <mxCell id="serviceLayer" value="&lt;b&gt;⑥ 校验核心与基础设施边界&lt;/b&gt;" style="swimlane;html=1;rounded=1;startSize=38;horizontal=1;fillColor=#f8fafc;strokeColor=#475569;fontColor=#0f172a;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1090" y="670" width="460" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="validator" value="&lt;b&gt;XmlValidator&lt;/b&gt;&lt;br&gt;validate(xmlPath, xsdPath)&lt;br&gt;执行 XML 格式良好性与 XSD Schema 校验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;align=left;spacing=8;" vertex="1" parent="serviceLayer">
          <mxGeometry x="25" y="55" width="195" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="xercesRuntime" value="&lt;b&gt;XercesRuntime&lt;/b&gt;&lt;br&gt;管理 Xerces-C++ 运行环境生命周期&lt;br&gt;由构造函数注入 MainWindow / Validator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;align=left;spacing=8;" vertex="1" parent="serviceLayer">
          <mxGeometry x="240" y="55" width="195" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="logManager" value="&lt;b&gt;LogManager / LogModule&lt;/b&gt;&lt;br&gt;记录 GUI 操作、文件选择、校验开始、阻断提示、重置等运行日志" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;align=left;spacing=8;" vertex="1" parent="serviceLayer">
          <mxGeometry x="25" y="165" width="195" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="domainModels" value="&lt;b&gt;领域 / 展示数据模型&lt;/b&gt;&lt;br&gt;ValidationResult / ValidationError&lt;br&gt;PresentedResult / PresentedError" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;align=left;spacing=8;" vertex="1" parent="serviceLayer">
          <mxGeometry x="240" y="165" width="195" height="80" as="geometry"/>
        </mxCell>

        <!-- 7. 主数据流 -->
        <mxCell id="flowTitle" value="&lt;b&gt;⑦ 主执行与数据流&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontColor=#166534;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="865" width="300" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="flow1" value="用户操作 / 拖放" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="920" width="150" height="55" as="geometry"/></mxCell>
        <mxCell id="flow2" value="MainWindow 槽函数" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4f46e5;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="245" y="920" width="165" height="55" as="geometry"/></mxCell>
        <mxCell id="flow3" value="validator_.validate()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#475569;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="455" y="920" width="165" height="55" as="geometry"/></mxCell>
        <mxCell id="flow4" value="ValidationResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="665" y="920" width="150" height="55" as="geometry"/></mxCell>
        <mxCell id="flow5" value="presenter_.present()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf4ff;strokeColor=#a21caf;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="860" y="920" width="170" height="55" as="geometry"/></mxCell>
        <mxCell id="flow6" value="PresentedResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf4ff;strokeColor=#a21caf;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1075" y="920" width="155" height="55" as="geometry"/></mxCell>
        <mxCell id="flow7" value="applyPresented() → 更新界面" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdfa;strokeColor=#0f766e;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1275" y="920" width="225" height="55" as="geometry"/></mxCell>

        <!-- 连接线 -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2563eb;strokeWidth=2;" edge="1" parent="1" source="eventLayer" target="mainWindow"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#4f46e5;strokeWidth=2;" edge="1" parent="1" source="mainWindow" target="viewLayer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="创建并持有" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#ea580c;strokeWidth=2;" edge="1" parent="1" source="mainWindow" target="supportLayer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="调用 initial / present" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#a21caf;strokeWidth=2;" edge="1" parent="1" source="mainWindow" target="presenterLayer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="调用校验 / 写日志" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#475569;strokeWidth=2;" edge="1" parent="1" source="mainWindow" target="serviceLayer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="回调绘制" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#f97316;" edge="1" parent="1" source="lineNumberArea" target="codeEditor"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="绑定 QTextDocument" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;dashed=1;strokeColor=#f97316;" edge="1" parent="1" source="highlighter" target="codeEditor"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="返回 ValidationResult" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;dashed=1;strokeColor=#64748b;" edge="1" parent="1" source="validator" target="domainModels"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="转换为 PresentedResult" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;dashed=1;strokeColor=#a21caf;" edge="1" parent="1" source="domainModels" target="presenter"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" value="运行环境依赖" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;endFill=0;dashed=1;strokeColor=#64748b;" edge="1" parent="1" source="xercesRuntime" target="validator"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="f1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="flow1" target="flow2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="flow2" target="flow3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="flow3" target="flow4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="flow4" target="flow5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="flow5" target="flow6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=2;" edge="1" parent="1" source="flow6" target="flow7"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- 图例 -->
        <mxCell id="legend" value="&lt;b&gt;图例&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#2563eb&quot;&gt;■&lt;/font&gt; 用户事件 / Qt入口　&lt;font color=&quot;#4f46e5&quot;&gt;■&lt;/font&gt; MainWindow协调　&lt;font color=&quot;#0f766e&quot;&gt;■&lt;/font&gt; 视图布局&lt;br&gt;&lt;font color=&quot;#ea580c&quot;&gt;■&lt;/font&gt; GUI支撑组件　&lt;font color=&quot;#a21caf&quot;&gt;■&lt;/font&gt; 展示适配　&lt;font color=&quot;#475569&quot;&gt;■&lt;/font&gt; 校验/基础设施" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;align=left;spacing=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="1020" width="780" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="&lt;b&gt;架构重点&lt;/b&gt;&lt;br&gt;MainWindow 不直接拼接领域错误信息，而是通过 ValidationResultPresenter 生成 PresentedResult，再统一渲染到 Qt 控件；CodeEditor 与高亮器负责 XML 预览和错误上下文展示。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;align=left;spacing=8;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="880" y="1020" width="620" height="80" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
